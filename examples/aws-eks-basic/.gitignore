# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Lock file
.terraform.lock.hcl

# Locally-pulled Helm chart (required manual pre-step, see gateway_operator.tf
# and README.md - working around a real terraform-provider-helm OCI-pull bug)
.charts/

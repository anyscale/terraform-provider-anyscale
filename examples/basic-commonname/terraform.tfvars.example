# Example terraform.tfvars file
# Copy this file to terraform.tfvars and fill in your values

# ============================================================================
# REQUIRED VARIABLES
# ============================================================================

# AWS Region
aws_region = "us-east-2"

# CIDR ranges allowed to access clusters (comma-separated)
# IMPORTANT: Restrict this in production! 0.0.0.0/0 allows access from anywhere
customer_ingress_cidr_ranges = "0.0.0.0/0"

# External ID for IAM trust policy
# This should be a unique identifier for your deployment
anyscale_external_id = "my-external-id-12345"

# Your Anyscale Organization ID
# Find this in the Anyscale console or CLI
anyscale_org_id = "org_abc123xyz"

# Name for your Anyscale cloud
cloud_name = "my-terraform-cloud"

# ============================================================================
# ANYSCALE AUTHENTICATION
# ============================================================================

# Option 1: Set token directly (recommended for CI/CD)
anyscale_token = "your-anyscale-token-here"

# Option 2: Leave this commented and use ANYSCALE_CLI_TOKEN environment variable
# export ANYSCALE_CLI_TOKEN="your-token"

# Option 3: Leave this commented and use ~/.anyscale/credentials.json
# {
#   "cli_token": "your-token"
# }

# ============================================================================
# OPTIONAL VARIABLES
# ============================================================================

# Deployment environment (production, development, or test)
anyscale_deploy_env = "production"

# Prefix for resource names (must be <= 30 characters)
common_prefix = "my-company-"

# Force destroy S3 bucket on terraform destroy (useful for testing)
# WARNING: Set to false in production to prevent accidental data loss
anyscale_s3_force_destroy = true

# Cloud provider (AWS, GCP, Azure, Generic)
cloud_provider = "AWS"

# Compute stack type (VM or K8s)
compute_stack = "VM"

# Whether this is a private cloud
is_private_cloud = false

# Whether to automatically add users
auto_add_user = false

# Optional: Anyscale Cloud ID (if updating existing cloud)
# anyscale_cloud_id = "cld_abc123xyz"

# Optional: Tags to apply to all resources
tags = {
  "environment" = "production"
  "team"        = "platform"
  "managed-by"  = "terraform"
}

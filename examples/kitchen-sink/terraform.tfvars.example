# Copy this file to terraform.tfvars and fill in your own values:
#   cp terraform.tfvars.example terraform.tfvars
# terraform.tfvars is gitignored in this repo -- your values are never committed.
#
# This example builds a real VPC, EKS cluster, S3 bucket, and IAM roles via modules, then registers
# two Anyscale clouds against them. Expect a 15-20+ minute apply and real AWS spend for as long as
# it stays up -- see README.md before running this.

# ---------------------------------------------------------------------------------------------------------------------
# REQUIRED -- shared identity / naming
# ---------------------------------------------------------------------------------------------------------------------

# Your Anyscale Organization ID (starts with "org_"). Find it at
# https://console.anyscale.com/ under Organization Settings.
anyscale_org_id = "org_abc123xyz"

# Free-form string used as the IAM trust policy external ID -- this example derives two distinct
# values from it internally (one per Anyscale cloud), so you only need to set it once here.
anyscale_external_id = "my-external-id-12345"

# Comma-delimited IPv4 CIDR ranges allowed to reach the VM legs (opens 443/https and 22/ssh).
# Replace with your own IP(s)/range(s) -- avoid "0.0.0.0/0" outside of throwaway testing.
customer_ingress_cidr_ranges = "203.0.113.0/24,198.51.100.42/32"

# ---------------------------------------------------------------------------------------------------------------------
# OPTIONAL -- defaults shown below match variables.tf; uncomment to override.
# ---------------------------------------------------------------------------------------------------------------------

# name_prefix = "kitchen-sink"
# aws_region  = "us-east-2"

# tags = {
#   Test        = "true"
#   Environment = "dev"
#   Example     = "kitchen-sink"
# }

# anyscale_deploy_env       = "test" # one of: production, development, test
# anyscale_s3_force_destroy = true

# --- EKS (Cloud A's K8S cloud resource) -------------------------------------------------------
# eks_cluster_version = "1.36"

# --- Compute configs ----------------------------------------------------------------------------
# head_node_instance_type = "m5.2xlarge"
# worker_instance_type    = "m5.4xlarge"

# --- Container images ---------------------------------------------------------------------------
# registry_image_uri = "docker.io/anyscale/ray:2.9.0-py310"

# --- Organization: sends a REAL email if set -----------------------------------------------------
# invite_email = "you+kitchen-sink@example.com"
# new_member_permission_level = "collaborator" # only used once you uncomment the collaborator block

# --- Service data sources: requires an already-running service to be meaningful ------------------
# existing_service_name = "my-service"
